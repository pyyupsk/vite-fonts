{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["typescript", "unicorn"],
  "categories": {
    "correctness": "error",
    "suspicious": "warn"
  },
  "rules": {
    "no-console": "warn",
    "unicorn/filename-case": [
      "error",
      {
        "case": "kebabCase"
      }
    ]
  },
  "ignorePatterns": ["dist", "node_modules"],
  "overrides": [
    {
      "files": ["src/cli/**"],
      "rules": {
        "no-console": "off"
      }
    }
  ]
}
