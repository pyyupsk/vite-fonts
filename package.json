{
  "name": "@pyyupsk/vite-fonts",
  "version": "0.1.0",
  "bin": {
    "vite-fonts": "./dist/cli/index.js"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./client": {
      "types": "./dist/client.d.ts"
    }
  },
  "scripts": {
    "build": "tsdown",
    "check": "bun run lint && bun run format:check",
    "format": "oxfmt .",
    "format:check": "oxfmt . --check",
    "lint": "oxlint .",
    "lint:fix": "oxlint . --fix",
    "prepare": "nit install",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@pyyupsk/nit": "^0.3.0",
    "@types/bun": "latest",
    "oxfmt": "^0.54.0",
    "oxlint": "^1.69.0",
    "tsdown": "^0.22.2",
    "vitest": "^4.1.8"
  },
  "peerDependencies": {
    "typescript": "^5",
    "vite": "^8.0.0"
  },
  "nit": {
    "hooks": {
      "pre-commit": "bun run check",
      "commit-msg": "bunx commitlint --edit $1"
    }
  }
}
